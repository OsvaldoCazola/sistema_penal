# Configuração da API Groq (LLM)
# Substitua o valor abaixo pela sua chave da API
GROQ_API_KEY=sua_chave_aqui

# Spring Profile (h2 para desenvolvimento, default para PostgreSQL)
SPRING_PROFILE=h2

# Configurações do Banco de Dados (para PostgreSQL)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=sistema_penal
# DB_USERNAME=postgres
# DB_PASSWORD=postgres

# Configurações de Email (opcional)
# MAIL_USERNAME=seu_email@gmail.com
# MAIL_PASSWORD=sua_senha

# JWT Secret (opcional, o padrão funciona)
# JWT_SECRET=sua_chave_secreta_aqui
